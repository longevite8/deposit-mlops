GIT_REPO=https://xxxxxx.git
GIT_BRANCH=vc-mco
CLEARML_REQUIREMENTS_FILE=requirements.txt

# ClearML client credentials.
# Either run `clearml-init` to create ~/.clearml/clearml.conf, or fill these values.
CLEARML_SERVER_URL=http://192.168.140.248:8080
CLEARML_API_ACCESS_KEY=replace-with-clearml-access-key
CLEARML_API_SECRET_KEY=replace-with-clearml-secret-key
CLEARML_API_HOST=http://192.168.140.248:8008
CLEARML_WEB_HOST=http://192.168.140.248:8080
CLEARML_FILES_HOST=http://192.168.140.248:8081

# Source database for deposit cashflow extraction
DB_USER=vega
DB_PASSWORD=replace-with-db-password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vc_mco_dev
DB_SCHEMA=public

# Deposit cashflow filters
SOURCE_PROJECT_NAME=Tin Vay
SOURCE_FLOW_TYPE=Vào
SOURCE_APPROVAL_STATUS=Đã duyệt
SOURCE_FROM_DATE=2025-01-01
SOURCE_TO_DATE=2026-01-01

# Forecast training overrides adapted from vc-mco-mlops/configs/training.yaml
FORECAST_UNIQUE_ID=Deposit_Portfolio
FORECAST_HORIZON=30
FORECAST_EVAL_HORIZON=30
FORECAST_INPUT_SIZE=90
FORECAST_LEARNING_RATE=0.0005
FORECAST_MAX_STEPS=100
FORECAST_LOSS=MAPE
FORECAST_OPTIMIZER=Adam
FORECAST_ACTIVATION=ReLU
FORECAST_CV_WINDOWS=2
FORECAST_START_PADDING_ENABLED=true
FORECAST_OUTPUT_DIR=results

# ClearML Serving deployment
CLEARML_SERVING_SERVICE_ID=
AUTO_CREATE_CLEARML_SERVING_SERVICE=false
CLEARML_SERVING_SERVICE_NAME=Deposit CashFlow Serving
CLEARML_SERVING_PROJECT=Deposit-CashFlow/Serving
CLEARML_SERVING_ENDPOINT_PREFIX=deposit/cashflow
CLEARML_SERVING_ENDPOINT=
CLEARML_SERVING_ENDPOINT_VERSION=
CLEARML_SERVING_PREPROCESS=serving/clearml_preprocess.py
CLEARML_SERVING_ENGINE=sklearn
CLEARML_SERVING_ALIAS=champion
CLEARML_SERVING_BASE_URL=http://127.0.0.1:8082
CLEARML_BASE_SERVING_URL=
CLEARML_SERVING_METRIC_LOG_FREQ=1.0
